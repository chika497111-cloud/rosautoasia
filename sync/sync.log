    <tr class="alt"><th>Обработчик</th><td>&nbsp;&nbsp;&nbsp;1C Web-service Extension</td></tr> 
    <tr><th>Код ошибки</th><td>&nbsp;&nbsp;&nbsp;0x00000000</td></tr> 
     
   </table> 
  </div> 
  <div id="details-right"> 
